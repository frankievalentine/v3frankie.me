---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found" currentPage="">
  <div class="max-w-lg mx-auto px-6 py-24 md:py-32 text-center">
    <p
      class="text-xs text-muted-foreground font-medium uppercase tracking-widest mb-6"
    >
      404
    </p>
    <h1 class="text-2xl font-bold tracking-tight text-foreground mb-3">
      Page not found
    </h1>
    <p class="text-sm text-muted-foreground leading-relaxed mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m12 19-7-7 7-7" />
        <path d="M19 12H5" />
      </svg>
      Back home
    </a>
  </div>
</Layout>
