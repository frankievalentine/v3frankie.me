---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Newsletter" currentPage="/newsletter">
  <div class="max-w-lg mx-auto px-6 py-12 md:py-16">
    <!-- Page header -->
    <div class="flex items-center gap-2 mb-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-muted-foreground"
        aria-hidden="true"
      >
        <rect width="20" height="16" x="2" y="4" rx="2" />
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
      </svg>
      <span
        class="text-xs text-muted-foreground font-medium uppercase tracking-wider"
        >Newsletter</span
      >
    </div>

    <!-- Subscribe card -->
    <div class="card">
      <header>
        <h1>Stay in the loop</h1>
        <p>
          Occasional essays on creative process, photography, and building
          things on the web. No noise — just signal.
        </p>
      </header>
      <section>
        <!-- Subscriber count pill -->
        <div class="flex items-center gap-2 mb-5">
          <div class="flex -space-x-2">
            <img
              class="size-6 rounded-full ring-2 ring-background object-cover"
              src="https://picsum.photos/seed/sub1/40/40"
              alt=""
              aria-hidden="true"
            >
            <img
              class="size-6 rounded-full ring-2 ring-background object-cover"
              src="https://picsum.photos/seed/sub2/40/40"
              alt=""
              aria-hidden="true"
            >
            <img
              class="size-6 rounded-full ring-2 ring-background object-cover"
              src="https://picsum.photos/seed/sub3/40/40"
              alt=""
              aria-hidden="true"
            >
          </div>
          <p class="text-xs text-muted-foreground">Join 240+ readers</p>
        </div>

        <!-- Form -->
        <form id="newsletter-form" class="grid gap-4" novalidate>
          <div class="grid gap-2">
            <label for="newsletter-name" class="label">Name</label>
            <input
              id="newsletter-name"
              class="input"
              type="text"
              placeholder="Your name"
              autocomplete="given-name"
              maxlength="100"
            >
            <p id="name-error" class="text-xs text-destructive" hidden></p>
          </div>
          <div class="grid gap-2">
            <label for="newsletter-email" class="label">
              Email <span class="text-destructive" aria-hidden="true">*</span>
            </label>
            <input
              id="newsletter-email"
              class="input"
              type="email"
              placeholder="you@example.com"
              autocomplete="email"
              required
              maxlength="254"
            >
            <p id="email-error" class="text-xs text-destructive" hidden></p>
          </div>
          <!-- Invisible Turnstile container — no visible widget rendered -->
          <div id="turnstile-container" style="display:none" aria-hidden="true"></div>
          <p id="form-error" class="text-xs text-destructive text-center" hidden></p>
          <button type="submit" class="btn w-full">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M22 2L11 13" />
              <path d="M22 2L15 22l-4-9-9-4 20-7z" />
            </svg>
            Subscribe
          </button>
          <p class="text-xs text-muted-foreground text-center">
            No spam, ever. Unsubscribe at any time.
          </p>
        </form>

        <!-- Success state -->
        <div id="newsletter-success" class="text-center py-4" hidden>
          <div
            class="inline-flex size-12 items-center justify-center rounded-full bg-secondary mb-4"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary-foreground"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5" />
            </svg>
          </div>
          <h3 class="font-semibold text-foreground mb-1">You're in</h3>
          <p class="text-sm text-muted-foreground">
            Thanks for subscribing. Check your inbox for a confirmation.
          </p>
        </div>
      </section>
    </div>

    <!-- What to expect section -->
    <div class="card mt-6">
      <header>
        <h2>What to expect</h2>
      </header>
      <section>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path
                d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
              />
              <circle cx="12" cy="13" r="3" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">Behind the lens</p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Notes on technique, gear decisions, and the thinking behind a
                shot.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                What I'm building
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Updates on open-source work, side projects, and things I find
                interesting.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">Cadence</p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Roughly twice a month. Never more than that.
              </p>
            </div>
          </li>
        </ul>
      </section>
    </div>
  </div>
</Layout>

<!-- Turnstile API — loaded only on this page, not via partytown -->
<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer></script>

<script>
  import { z } from "zod";

  // Replace with your actual site key from dash.cloudflare.com/turnstile
  const TURNSTILE_SITE_KEY = "0x4AAAAAAClOSfZj9R_ZSuqv";

  const schema = z.object({
    email: z
      .string()
      .min(1, "Email is required")
      .email("Please enter a valid email address")
      .max(254, "Email is too long"),
    name: z
      .string()
      .max(100, "Name must be 100 characters or fewer")
      .transform((v) => v.trim().replace(/[<>]/g, ""))
      .optional(),
  });

  const form = document.getElementById(
    "newsletter-form",
  ) as HTMLFormElement | null;
  const success = document.getElementById("newsletter-success");
  const emailInput = document.getElementById(
    "newsletter-email",
  ) as HTMLInputElement | null;
  const nameInput = document.getElementById(
    "newsletter-name",
  ) as HTMLInputElement | null;
  const submitBtn = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement | null;
  const emailError = document.getElementById("email-error");
  const nameError = document.getElementById("name-error");
  const formError = document.getElementById("form-error");
  const turnstileContainer = document.getElementById("turnstile-container");

  // Render the invisible Turnstile widget once — widget is hidden, executes on submit.
  let widgetId: string | undefined;
  let pendingResolve: ((token: string) => void) | null = null;
  let pendingReject: ((err: Error) => void) | null = null;

  const renderTurnstile = () => {
    if (!turnstileContainer || !(window as any).turnstile || widgetId !== undefined) return;
    widgetId = (window as any).turnstile.render(turnstileContainer, {
      sitekey: TURNSTILE_SITE_KEY,
      size: "invisible",
      execution: "execute",
      callback: (token: string) => {
        pendingResolve?.(token);
        pendingResolve = null;
        pendingReject = null;
      },
      "error-callback": () => {
        pendingReject?.(new Error("Verification failed. Please try again."));
        pendingResolve = null;
        pendingReject = null;
      },
    });
  };

  // Turnstile may load before or after this script — handle both cases.
  if ((window as any).turnstile) {
    renderTurnstile();
  } else {
    (window as any).__onTurnstileLoad = renderTurnstile;
  }

  const getToken = (): Promise<string> => {
    if (widgetId === undefined) {
      return Promise.reject(new Error("Verification not ready. Please try again."));
    }
    return new Promise((resolve, reject) => {
      pendingResolve = resolve;
      pendingReject = reject;
      (window as any).turnstile.reset(widgetId);
      (window as any).turnstile.execute(widgetId);
    });
  };

  const clearErrors = () => {
    emailInput?.removeAttribute("aria-invalid");
    nameInput?.removeAttribute("aria-invalid");
    if (emailError) { emailError.textContent = ""; emailError.hidden = true; }
    if (nameError) { nameError.textContent = ""; nameError.hidden = true; }
    if (formError) { formError.textContent = ""; formError.hidden = true; }
  };

  const showFormError = (msg: string) => {
    if (formError) { formError.textContent = msg; formError.hidden = false; }
  };

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    const raw = {
      email: emailInput?.value ?? "",
      name: nameInput?.value || undefined,
    };

    const result = schema.safeParse(raw);
    if (!result.success) {
      const issues = result.error.flatten().fieldErrors;
      if (issues.email?.[0]) {
        emailInput?.setAttribute("aria-invalid", "true");
        if (emailError) { emailError.textContent = issues.email[0]; emailError.hidden = false; }
        emailInput?.focus();
      }
      if (issues.name?.[0]) {
        nameInput?.setAttribute("aria-invalid", "true");
        if (nameError) { nameError.textContent = issues.name[0]; nameError.hidden = false; }
      }
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Verifying…";
    }

    let token: string;
    try {
      token = await getToken();
    } catch (err) {
      showFormError(err instanceof Error ? err.message : "Verification failed. Please try again.");
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = "Subscribe"; }
      return;
    }

    if (submitBtn) submitBtn.textContent = "Subscribing…";

    try {
      const body = new URLSearchParams({ email: result.data.email });
      if (result.data.name) body.set("name", result.data.name);
      body.set("cf-turnstile-response", token);

      const res = await fetch("https://newsletter.v3frankie.me/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: body.toString(),
      });

      if (!res.ok) throw new Error("Request failed");

      form.setAttribute("hidden", "");
      success?.removeAttribute("hidden");
    } catch {
      showFormError("Something went wrong. Please try again.");
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = "Subscribe"; }
    }
  });

  emailInput?.addEventListener("input", () => {
    emailInput.removeAttribute("aria-invalid");
    if (emailError) { emailError.textContent = ""; emailError.hidden = true; }
  });

  nameInput?.addEventListener("input", () => {
    nameInput.removeAttribute("aria-invalid");
    if (nameError) { nameError.textContent = ""; nameError.hidden = true; }
  });
</script>
