---
import Layout from "../layouts/Layout.astro";

const photos = [
  {
    src: "https://images.unsplash.com/photo-1678757603916-a63283ffe93d?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "blue car parked in a parking lot",
    link: "https://unsplash.com/photos/a-blue-car-parked-in-a-parking-lot-KrPYULc4JPU",
  },
  {
    src: "https://images.unsplash.com/photo-1678762389792-9f85f6509ea9?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "woman holding a baby in her arms",
    link: "https://unsplash.com/photos/a-woman-holding-a-baby-in-her-arms-83jldfu9voE",
  },
  {
    src: "https://images.unsplash.com/photo-1678757604007-da979fc8aaaa?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "desk setup with monitor and laptop",
    link: "https://unsplash.com/photos/s9YI0SfZ7Oc",
  },
  {
    src: "https://images.unsplash.com/photo-1678757604327-8b445513dc0c?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "sidewalk view with a row of benches and a coffee shop",
    link: "https://unsplash.com/photos/a-row-of-benches-sitting-on-the-side-of-a-street-52EIZuSZ3Po",
  },
  {
    src: "https://images.unsplash.com/photo-1512429234305-12fe5b0b0f07?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "macbook beside headphones and a plant",
    link: "https://unsplash.com/photos/macbook-beside-headphones-lg35FkimT30",
  },
  {
    src: "https://images.unsplash.com/photo-1525477800099-be89f80b4dac?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "white audio technica wireless turntable near vinyl record sleeve",
    link: "https://unsplash.com/photos/white-audio-technica-wireless-turntable-near-vinyl-record-sleeve-oOHEXf88gNY",
  },
  {
    src: "https://images.unsplash.com/photo-1519001896312-85f41baa90a0?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "orange and white class a motorhome surrounded by snow",
    link: "https://unsplash.com/photos/orange-and-white-class-a-motorhome-surrounded-by-snow-id7EXciI1fY",
  },
  {
    src: "https://images.unsplash.com/photo-1546550613-799015025b71?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "photography of the pacific ocean from mexico",
    link: "https://unsplash.com/photos/aerial-photography-of-sea-GpejUx28Hmw",
  },
  {
    src: "https://images.unsplash.com/photo-1527814050087-3793815479db?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "white and grey logitech g series cordless mouse on white surface",
    link: "https://unsplash.com/photos/white-and-grey-logitech-g-series-cordless-mouse-on-white-surface-VghbBAYqUJ0",
  },
  {
    src: "https://images.unsplash.com/photo-1546550519-c8f2744e7438?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "blue and red stage lights",
    link: "https://unsplash.com/photos/blue-and-red-stage-lights-k0JC8E5kXo0",
  },
  {
    src: "https://images.unsplash.com/photo-1519236282064-01649736e20b?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "gray and white wooden house near green leaf tree",
    link: "https://unsplash.com/photos/gray-and-white-wooden-house-near-green-leaf-tree-WWS9i5_Q8vE",
  },
  {
    src: "https://images.unsplash.com/photo-1632179046409-e201ec20f079?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
    alt: "a coffee shop with a neon sign above the counter",
    link: "https://unsplash.com/photos/a-coffee-shop-with-a-neon-sign-above-the-counter-7goSUGIMpeY",
  },
];
---

<Layout title="Photography" currentPage="/photography">
  <div class="px-6 py-12 md:py-16">
    <!-- Page header -->
    <div class="max-w-2xl mb-10">
      <div class="flex items-center gap-2 mb-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-muted-foreground"
          aria-hidden="true"
        >
          <path
            d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
          />
          <circle cx="12" cy="13" r="3" />
        </svg>
        <span
          class="text-xs text-muted-foreground font-medium uppercase tracking-wider"
          >Photography</span
        >
      </div>
      <h1 class="text-3xl font-bold tracking-tight">Selected frames</h1>
      <p class="mt-2 text-muted-foreground text-sm leading-relaxed">
        A curated collection from ongoing series shot around the Bay Area and
        beyond. All images captured on film and 35mm digital.
      </p>
    </div>

    <!-- Masonry grid via CSS columns -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-4">
      {photos.map((photo) => (
        <div class="break-inside-avoid mb-4">
          <a href={photo.link} target="_blank" rel="noopener noreferrer">
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class="w-full rounded-md"
            />
          </a>
        </div>
      ))}
    </div>
  </div>
</Layout>
