---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Uses" currentPage="/uses">
  <div class="max-w-lg mx-auto px-6 py-12 md:py-16">
    <!-- Page header -->
    <div class="flex items-center gap-2 mb-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-muted-foreground"
        aria-hidden="true"
      >
        <path
          d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
        />
      </svg>
      <span
        class="text-xs text-muted-foreground font-medium uppercase tracking-wider"
        >Uses</span
      >
    </div>

    <div class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight text-foreground mb-2">
        What I use
      </h1>
      <p class="text-sm text-muted-foreground">
        Hardware, software, and tools I rely on day-to-day. Updated
        occasionally.
      </p>
    </div>

    <!-- Hardware -->
    <div class="card mb-6">
      <header>
        <h2>Hardware</h2>
      </header>
      <section>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <rect width="18" height="12" x="3" y="4" rx="2" ry="2" />
              <line x1="2" x2="22" y1="20" y2="20" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                MacBook Pro 14" M3 Pro
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Primary machine. The jump from Intel was significant; the M3 is
                barely worth upgrading from M1/M2 unless you're GPU-bound.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <rect width="20" height="14" x="2" y="3" rx="2" />
              <line x1="8" x2="16" y1="21" y2="21" />
              <line x1="12" x2="12" y1="17" y2="21" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                LG UltraFine 27" 4K
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                External display. Good enough for photo editing; not a
                substitute for a calibrated panel.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path
                d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"
              />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                Keychron Q2 Pro
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                75% layout, Gateron G Pro Red switches. Wireless when I need it,
                wired otherwise.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path
                d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
              />
              <circle cx="12" cy="13" r="3" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                Sony A7C II
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Daily carry camera. Compact full-frame with great AF. Paired
                mostly with the 35mm f/1.8.
              </p>
            </div>
          </li>
        </ul>
      </section>
    </div>

    <!-- Development Stack -->
    <div class="card mb-6">
      <header>
        <h2>Development Stack</h2>
      </header>
      <section>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                VS Code + Neovim
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                VS Code for anything with heavy tooling requirements, Neovim for
                everything else. Still switching between them too often.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
              <line x1="3" x2="21" y1="9" y2="9" />
              <line x1="3" x2="21" y1="15" y2="15" />
              <line x1="9" x2="9" y1="9" y2="21" />
              <line x1="15" x2="15" y1="9" y2="21" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                Ghostty
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Replaced iTerm2. Fast, native, and the config format is sane.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path d="m9 9-2 2 2 2" />
              <path d="m13 13 2-2-2-2" />
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.35-4.35" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                TypeScript + Bun
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                TypeScript everywhere. Bun as runtime, package manager, and test
                runner — it's fast enough that I stopped thinking about it.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z" />
              <path d="M7 7h.01" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                Astro + React + Tailwind CSS
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Astro for content sites and static work, React when I need
                component-heavy UIs. Tailwind for both.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <ellipse cx="12" cy="5" rx="9" ry="3" />
              <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
              <path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                Cloudflare Pages + Workers
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Default deployment target. The edge network and free tier make
                it hard to justify self-hosting for most projects.
              </p>
            </div>
          </li>
        </ul>
      </section>
    </div>

    <!-- Apps -->
    <div class="card">
      <header>
        <h2>Apps</h2>
      </header>
      <section>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">Notion</p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Project planning and long-form notes. Would prefer something
                local-first but haven't found a good replacement yet.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10" />
              <line x1="2" x2="22" y1="12" y2="12" />
              <path
                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
              />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">Arc</p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Primary browser. Spaces keep work and personal contexts
                separate. Using it less aggressively as development slows.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path
                d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
              />
              <circle cx="12" cy="13" r="3" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">
                Lightroom Classic
              </p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Still the best cataloging and editing workflow for high-volume
                shooting. Capture One is better technically; the library
                management isn't.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-foreground">Linear</p>
              <p class="text-xs text-muted-foreground mt-0.5">
                Issue tracking for client work and larger personal projects.
                Opinionated in the right ways.
              </p>
            </div>
          </li>
        </ul>
      </section>
    </div>
  </div>
</Layout>
