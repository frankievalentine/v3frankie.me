---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../utils";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Posts" currentPage="/posts">
  <div class="max-w-2xl mx-auto px-6 py-12 md:py-16">
    <!-- Page header -->
    <div class="flex items-center gap-2 mb-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-muted-foreground"
        aria-hidden="true"
      >
        <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
        <path d="M14 2v4a2 2 0 0 0 2 2h4" />
        <path d="M10 9H8" />
        <path d="M16 13H8" />
        <path d="M16 17H8" />
      </svg>
      <span
        class="text-xs text-muted-foreground font-medium uppercase tracking-wider"
        >Writing</span
      >
    </div>
    <h1 class="text-3xl font-bold tracking-tight mb-2">Posts</h1>
    <p class="text-muted-foreground text-sm mb-10">
      Notes on photography, engineering, and the overlap between them.
    </p>

    <!-- Post list -->
    <div class="grid gap-4">
      {posts.map((post) => (
        <a href={`/posts/${post.id}`} class="block group">
          <div class="card transition-colors group-hover:bg-accent/40">
            <section>
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <h2 class="text-base font-semibold text-foreground leading-snug group-hover:text-foreground mb-1">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
                    {post.data.description}
                  </p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0 mt-1 transition-transform group-hover:translate-x-0.5" aria-hidden="true">
                  <path d="M5 12h14"/>
                  <path d="m12 5 7 7-7 7"/>
                </svg>
              </div>

              <div class="flex items-center gap-3 mt-3">
                <time datetime={post.data.date.toISOString()} class="text-xs text-muted-foreground">
                  {formatDate(post.data.date)}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex gap-1.5 flex-wrap">
                    {post.data.tags.map((tag) => (
                      <span class="badge-secondary text-xs">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </section>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
