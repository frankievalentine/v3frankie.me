---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Search from '../components/Search.astro';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'Frankie Valentine',
  description = "Frankie Valentine's personal website — photographer, engineer, and founder of V3 Digital Studio.",
  currentPage = '/',
} = Astro.props;

const siteTitle = title === 'Frankie Valentine' ? title : `${title} • Frankie Valentine`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="Frankie Valentine" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Frankie Valentine" />
    <meta property="og:locale" content="en_US" />
    <meta property="article:author" content="Frankie Valentine" />

    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description} />

    <!-- Theme color -->
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1d1f21" media="(prefers-color-scheme: dark)" />

    <!-- Sitemap + RSS -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Frankie Valentine" href="/rss.xml" />

    <!-- Analytics (via Partytown) -->
    <script
      is:inline
      defer
      type="text/partytown"
      data-domain="v3frankie.me"
      data-site-id="2"
      src="https://analytics.v3frankie.net/api/script.js"
    ></script>

    <ClientRouter />
    <script is:inline>
      if (
        localStorage.theme === 'dark' ||
        (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-svh bg-background text-foreground antialiased">

    <Search />

    <aside class="sidebar" data-side="left" data-pagefind-ignore>
      <nav>

        <section class="scrollbar">
          <!-- Search trigger -->
          <div class="px-2 pt-2">
            <button
              id="search-trigger"
              type="button"
              aria-label="Search"
              class="flex w-full items-center gap-2 rounded-md h-8 px-2 text-sm text-muted-foreground bg-sidebar-accent/60 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground border border-sidebar-border transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.3-4.3"/>
              </svg>
              <span class="flex-1 text-left text-xs">Search...</span>
              <span class="kbd hidden sm:inline-flex">
                <span>⌘</span><span>K</span>
              </span>
            </button>
          </div>

          <div role="group">
            <ul>
              <li>
                <a href="/" aria-current={currentPage === '/' ? 'page' : undefined}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                  </svg>
                  <span>About</span>
                </a>
              </li>
              <li>
                <a href="/posts" aria-current={currentPage === '/posts' || currentPage.startsWith('/posts/') ? 'page' : undefined}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
                    <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
                    <path d="M10 9H8"/>
                    <path d="M16 13H8"/>
                    <path d="M16 17H8"/>
                  </svg>
                  <span>Posts</span>
                </a>
              </li>
              <li>
                <a href="/photography" aria-current={currentPage === '/photography' ? 'page' : undefined}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
                    <circle cx="12" cy="13" r="3"/>
                  </svg>
                  <span>Photography</span>
                </a>
              </li>
              <li>
                <a href="/newsletter" aria-current={currentPage === '/newsletter' ? 'page' : undefined}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  <span>Newsletter</span>
                </a>
              </li>
            </ul>
          </div>
        </section>

        <footer>
          <!-- User profile popover — avatar trigger at bottom of sidebar -->
          <div class="popover w-full" data-keep-mobile-sidebar-open>
            <button
              type="button"
              aria-expanded="false"
              aria-controls="user-popover"
              data-keep-mobile-sidebar-open
              class="flex w-full items-center gap-3 rounded-md p-2 text-left text-sm outline-none ring-sidebar-ring hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-2 transition-colors h-12"
            >
              <!-- Avatar -->
              <img
                class="size-8 shrink-0 rounded-full object-cover ring-1 ring-sidebar-border"
                src="/avatar.jpg"
                alt="Frankie"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <div
                class="size-8 shrink-0 rounded-full bg-sidebar-accent text-sidebar-accent-foreground items-center justify-center text-sm font-semibold ring-1 ring-sidebar-border"
                style="display:none"
              >
                F
              </div>
              <!-- Identity -->
              <div class="grid flex-1 text-left leading-tight min-w-0">
                <span class="truncate text-sm font-semibold text-sidebar-foreground">Frankie</span>
                <span class="truncate text-xs text-muted-foreground">Photographer &amp; Engineer</span>
              </div>
              <!-- Chevron up indicator -->
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted-foreground" aria-hidden="true">
                <path d="m18 15-6-6-6 6"/>
              </svg>
            </button>

            <!-- Popover panel — opens upward -->
            <div
              id="user-popover"
              data-popover
              data-side="top"
              data-align="start"
              aria-hidden="true"
              class="w-56"
            >
              <!-- Identity header -->
              <div class="px-3 py-2.5 border-b border-border">
                <p class="text-sm font-semibold truncate">Frankie</p>
                <p class="text-xs text-muted-foreground truncate mt-0.5">Photographer &amp; Engineer</p>
                <span class="badge-outline text-xs mt-2 inline-flex">Open to work</span>
              </div>

              <!-- Social links -->
              <div class="py-1">
                <a
                  href="https://github.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2.5 px-3 py-2 text-sm rounded-sm hover:bg-accent hover:text-accent-foreground transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0" aria-hidden="true">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                  </svg>
                  GitHub
                </a>
                <a
                  href="https://x.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2.5 px-3 py-2 text-sm rounded-sm hover:bg-accent hover:text-accent-foreground transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0" aria-hidden="true">
                    <path d="M4 4l11.733 16H20L8.267 4z"/>
                    <path d="M4 20L15.733 4"/>
                  </svg>
                  X / Twitter
                </a>
                <a
                  href="https://instagram.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2.5 px-3 py-2 text-sm rounded-sm hover:bg-accent hover:text-accent-foreground transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0" aria-hidden="true">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                  </svg>
                  Instagram
                </a>
              </div>

              <!-- Divider + theme toggle -->
              <div class="border-t border-border py-1">
                <button
                  id="theme-toggle"
                  type="button"
                  aria-label="Toggle theme"
                  class="flex w-full items-center gap-2.5 px-3 py-2 text-sm rounded-sm hover:bg-accent hover:text-accent-foreground transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0 hidden dark:block" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"/>
                    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0 block dark:hidden" aria-hidden="true">
                    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
                  </svg>
                  <span class="dark:hidden">Dark mode</span>
                  <span class="hidden dark:inline">Light mode</span>
                </button>
              </div>
            </div>
          </div>
        </footer>

      </nav>
    </aside>

    <!-- Sibling of .sidebar — gets auto margin from basecoat sidebar CSS -->
    <div class="flex flex-col min-h-svh">
      <!-- Mobile top bar -->
      <header class="flex items-center gap-3 px-4 h-14 border-b border-border shrink-0 md:hidden" data-pagefind-ignore>
        <button
          type="button"
          onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
          aria-label="Open menu"
          class="inline-flex size-8 items-center justify-center rounded-md hover:bg-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" x2="20" y1="6" y2="6"/>
            <line x1="4" x2="20" y1="12" y2="12"/>
            <line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </button>
      </header>

      <main class="flex-1 pb-16">
        <slot />
      </main>
    </div>

    <script>
      import 'basecoat-css/all';
      import type { TransitionBeforeSwapEvent } from 'astro:transitions/client';

      // Transfer the dark class to the incoming document before the swap so the
      // theme never flashes. The new page's <html> is server-rendered without the
      // class; astro:before-swap lets us patch it before it hits the DOM.
      document.addEventListener('astro:before-swap', (e) => {
        const isDark = document.documentElement.classList.contains('dark');
        (e as TransitionBeforeSwapEvent).newDocument.documentElement.classList.toggle('dark', isDark);
        // Restore body scroll before the page swaps out.
        document.body.style.overflow = '';
      });

      // Re-initialize basecoat after each View Transition page swap.
      // The MutationObserver in basecoat.js watches document.body — when Astro
      // replaces the body element the observer is lost. stop() + initAll() + start()
      // re-attaches it to the new body and re-initializes all components.
      let sidebarObserver: MutationObserver | null = null;

      document.addEventListener('astro:page-load', () => {
        window.basecoat?.stop();
        window.basecoat?.initAll();
        window.basecoat?.start();

        // Lock body scroll while the mobile sidebar is open to prevent Safari
        // from scrolling the page behind the overlay (which causes the sidebar
        // footer to disappear due to a fixed-element compositing bug).
        sidebarObserver?.disconnect();
        const sidebar = document.querySelector('.sidebar');
        if (sidebar) {
          const syncScroll = () => {
            document.body.style.overflow = sidebar.hasAttribute('inert') ? '' : 'hidden';
          };
          syncScroll();
          sidebarObserver = new MutationObserver(syncScroll);
          sidebarObserver.observe(sidebar, { attributes: true, attributeFilter: ['inert'] });
        }
      });

      // Use event delegation on document so listeners survive body swaps.
      document.addEventListener('click', (e) => {
        const target = e.target as Element;

        if (target.closest('#theme-toggle')) {
          document.documentElement.classList.toggle('dark');
          localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
        }

        if (target.closest('#search-trigger')) {
          (document.getElementById('search-dialog') as HTMLDialogElement)?.showModal();
          document.getElementById('search-input')?.focus();
        }
      });
    </script>

  </body>
</html>
